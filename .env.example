# Environment
ENVIRONMENT=development
DEBUG=false

# Application
APP_NAME="Filymore OS"
APP_HOST=127.0.0.1
APP_PORT=8000

# Database
DATABASE_URL=

# Logging
LOG_LEVEL=INFO

# Amazon Ads placeholders
AMAZON_ADS_CLIENT_ID=
